  const a = document.getElementById('cbA').value.trim();
  const w = document.getElementById('cbW').value.split(',').map(s => s.trim()).filter(Boolean);
  if (!q || !a || w.length < 1) { alert('Need a question, an answer, and at least 1 wrong choice.'); return; }
  const saved = ls_get(STORE.custom, []);
  saved.push({ q, a, w });
  ls_set(STORE.custom, saved);
  renderCustomBuilder();
};
window.delCustomQ = function(i) {
  const saved = ls_get(STORE.custom, []);
  saved.splice(i, 1);
  ls_set(STORE.custom, saved);
  renderCustomBuilder();
};
window.clearCustom = function() {
  if (!confirm('Delete ALL your custom questions?')) return;
  ls_set(STORE.custom, []);
  renderCustomBuilder();
};
window.exportCustom = function() {
  const saved = ls_get(STORE.custom, []);
  const blob = new Blob([JSON.stringify(saved, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `gridiron-quiz-${todayKey()}.json`;
  a.click();
  URL.revokeObjectURL(a.href);
};
window.importCustom = function() {
  const inp = document.createElement('input');
  inp.type = 'file'; inp.accept = '.json';
  inp.onchange = e => {
    const f = e.target.files[0]; if (!f) return;
    const reader = new FileReader();
    reader.onload = () => {
      try {
        const data = JSON.parse(reader.result);
        if (!Array.isArray(data)) throw 'bad';
        const saved = ls_get(STORE.custom, []);
        ls_set(STORE.custom, saved.concat(data));
        renderCustomBuilder();
      } catch(e) { alert('Invalid JSON file.'); }
    };
    reader.readAsText(f);
  };
  inp.click();
};
window.playCustom = function() {
  const saved = ls_get(STORE.custom, []);
