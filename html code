function daysUntilMichiganGame() {
  // The Game is traditionally the last Saturday of November (rivalry week)
  const now = new Date();
  const yr = now.getFullYear();
  // Approximate: last Saturday of November
  let d = new Date(yr, 10, 30);
  while (d.getDay() !== 6) d.setDate(d.getDate() - 1);
  if (d < now) {
    d = new Date(yr + 1, 10, 30);
    while (d.getDay() !== 6) d.setDate(d.getDate() - 1);
  }
  const diff = d - now;
  return {
    days: Math.floor(diff / (1000*60*60*24)),
    hours: Math.floor((diff / (1000*60*60)) % 24),
    minutes: Math.floor((diff / (1000*60)) % 60),
    when: d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  };
}

