async function loadTeams() {
  const cached = ls_get(STORE.teams, null);
  if (cached && cached.ts && (Date.now() - cached.ts < 7*24*60*60*1000) && cached.teams && cached.teams.length > 100) {
    state.teams = cached.teams;
    organizeTeams();
    return;
  }
  try {
    const r = await fetch('https://site.api.espn.com/apis/site/v2/sports/football/college-football/teams?limit=500');
    const d = await r.json();
    const espnTeams = (d?.sports?.[0]?.leagues?.[0]?.teams || []).map(t => {
      const team = t.team || {};
      return {
        id: team.id,
        name: team.location || team.shortDisplayName,
        fullName: team.displayName || team.name,
        mascot: team.name,
        abbreviation: team.abbreviation,
        color: team.color ? '#' + team.color : '#666',
        altColor: team.alternateColor ? '#' + team.alternateColor : '#fff',
        logo: team.logos?.[0]?.href || `https://a.espncdn.com/i/teamlogos/ncaa/500/${team.id}.png`,
        division: 'FBS'
      };
    });
    espnTeams.forEach(t => {
      t.conference = FBS_CONFERENCE_MAP[t.fullName] || FBS_CONFERENCE_MAP[t.name] || 'FBS Independent';
      const cm = FBS_CITY_MAP[t.fullName] || FBS_CITY_MAP[t.name];
      t.city = cm?.city || '';
      t.state = cm?.state || '';
    });
    const fcsTeams = FCS_SUPPLEMENT.map(t => ({
      ...t,
      fullName: `${t.name} ${t.mascot}`,
      logo: `https://a.espncdn.com/i/teamlogos/ncaa/500/${t.id}.png`,
      color: '#666', altColor: '#fff'
    }));
    state.teams = [...espnTeams, ...fcsTeams];
    ls_set(STORE.teams, { ts: Date.now(), teams: state.teams });
    organizeTeams();
  } catch(e) {
    console.warn('ESPN fetch failed, using FCS supplement only:', e);
    state.teams = FCS_SUPPLEMENT.map(t => ({
      ...t,
      fullName: `${t.name} ${t.mascot}`,
      logo: `https://a.espncdn.com/i/teamlogos/ncaa/500/${t.id}.png`,
      color: '#666', altColor: '#fff'
    }));
    organizeTeams();
  }
}

function organizeTeams() {
  state.byDivision = { FBS: [], FCS: [] };
  state.byConference = {};
  state.teams.forEach(t => {
    const div = t.division || 'FBS';
    state.byDivision[div].push(t);
    const conf = t.conference || 'Other';
    state.byConference[conf] = state.byConference[conf] || [];
    state.byConference[conf].push(t);
  });
  document.getElementById('hsFbs').textContent = state.byDivision.FBS.length;
  document.getElementById('hsFcs').textContent = state.byDivision.FCS.length;
  document.getElementById('hsConf').textContent = Object.keys(state.byConference).filter(c => c !== 'Other' && c !== 'FBS Independent').length;
}

function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
function pickN(arr, n, exclude) {
  const pool = arr.filter(x => !exclude || !exclude.includes(x));
  const out = [];
  while (out.length < n && pool.length) {
    const i = Math.floor(Math.random() * pool.length);
    out.push(pool.splice(i, 1)[0]);
  }
  return out;
}
function shuffle(a) { for (let i = a.length-1; i > 0; i--) { const j = Math.floor(Math.random()*(i+1)); [a[i],a[j]] = [a[j],a[i]]; } return a; }

function poolFor(filter) {
  const div = filter?.division || 'all';
  const conf = filter?.conference || 'all';
  let pool = state.teams.slice();
  if (div !== 'all') pool = pool.filter(t => (t.division || 'FBS') === div);
  if (conf !== 'all') pool = pool.filter(t => t.conference === conf);
  return pool;
}

function bumpScore(mode, correct, total) {
  state.scores.games++;
  state.scores.correct += correct;
  state.scores.byMode[mode] = state.scores.byMode[mode] || { games:0, correct:0, total:0 };
  state.scores.byMode[mode].games++;
  state.scores.byMode[mode].correct += correct;
  state.scores.byMode[mode].total += total;
  ls_set(STORE.scores, state.scores);
  const pct = total ? Math.round(correct/total*100) : 0;
  if (!state.best[mode] || pct > state.best[mode].pct) {
    state.best[mode] = { pct, correct, total, date: new Date().toISOString().slice(0,10) };
    ls_set(STORE.best, state.best);
  }
  if (correct === total && total > 0) state.streak++;
  else state.streak = 0;
  ls_set(STORE.streak, state.streak);
  updateScoreUI();
}

function escapeHtml(s) { return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

