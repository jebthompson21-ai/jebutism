<!doctype html>

<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
<title>GRIDIRON IQ · College Football Trivia</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Bebas+Neue&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&family=Bungee&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0a0c;
  --bg-2: #131316;
  --bg-3: #1c1c20;
  --panel: #16161a;
  --border: #28282e;
  --border-2: #34343c;
  --text: #f4f1ea;
  --text-2: #b0aca3;
  --text-3: #6e6a62;

–scarlet: #BB0000;
–scarlet-hot: #ff1f1f;
–gray: #666666;
–bone: #F5F0E1;
–gold: #f0b738;
–green: #2ecc71;
–red-neg: #ff4d4d;

–maize: #FFCB05;
–blue: #00274C;

–display: ‘Anton’, ‘Bebas Neue’, sans-serif;
–subhead: ‘Bebas Neue’, sans-serif;
–body: ‘Manrope’, system-ui, sans-serif;
–mono: ‘JetBrains Mono’, monospace;
–decal: ‘Bungee’, sans-serif;

–r-sm: 6px;
–r: 10px;
–r-lg: 16px;
–shadow: 0 4px 14px rgba(0,0,0,.4), 0 1px 0 rgba(255,255,255,.04) inset;
–shadow-lg: 0 14px 40px rgba(0,0,0,.55), 0 1px 0 rgba(255,255,255,.06) inset;
}

- { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
  background:
  radial-gradient(1100px 600px at 80% -10%, rgba(187,0,0,.08), transparent 60%),
  radial-gradient(900px 500px at 0% 110%, rgba(187,0,0,.04), transparent 60%),
  var(–bg);
  color: var(–text);
  font-family: var(–body);
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  }
  body::before {
  content: “”;
  position: fixed; inset: 0;
  background-image:
  repeating-linear-gradient(
  90deg,
  transparent 0 80px,
  rgba(255,255,255,.012) 80px 81px
  );
  pointer-events: none;
  z-index: 0;
  }
  .app { position: relative; z-index: 1; }

/* ===== TOPBAR ===== */
.topbar {
display: flex; align-items: center; justify-content: space-between;
padding: 14px 20px;
border-bottom: 1px solid var(–border);
background: linear-gradient(180deg, rgba(0,0,0,.5), rgba(0,0,0,.15));
position: sticky; top: 0; z-index: 50;
backdrop-filter: blur(18px);
}
.brand {
display: flex; align-items: center; gap: 14px;
}
.brand-mark {
width: 38px; height: 38px;
display: grid; place-items: center;
background: var(–scarlet);
border-radius: 6px;
font-family: var(–decal);
font-size: 18px;
color: #fff;
letter-spacing: .5px;
box-shadow: 0 6px 16px rgba(187,0,0,.4), 0 1px 0 rgba(255,255,255,.2) inset;
transform: rotate(-3deg);
}
.brand-name {
font-family: var(–display);
font-size: 26px;
letter-spacing: 2.5px;
line-height: 1;
}
.brand-sub {
font-family: var(–mono);
font-size: 10px;
color: var(–text-3);
letter-spacing: 2px;
text-transform: uppercase;
}
.score-pill {
display: flex; align-items: center; gap: 12px;
padding: 8px 14px;
background: var(–bg-2);
border: 1px solid var(–border);
border-radius: 999px;
font-family: var(–mono);
font-size: 12px;
}
.score-pill .lbl { color: var(–text-3); text-transform: uppercase; letter-spacing: 1.5px; font-size: 10px; }
.score-pill .val { color: var(–scarlet-hot); font-weight: 700; font-size: 14px; }

/* ===== TABS ===== */
.tabs {
display: flex;
gap: 4px;
padding: 8px 16px 0;
border-bottom: 1px solid var(–border);
background: var(–bg-2);
overflow-x: auto;
scrollbar-width: none;
position: sticky; top: 67px; z-index: 49;
}
.tabs::-webkit-scrollbar { display: none; }
.tab {
flex-shrink: 0;
padding: 12px 18px;
font-family: var(–subhead);
font-size: 14px;
letter-spacing: 1.8px;
text-transform: uppercase;
color: var(–text-3);
border-bottom: 2px solid transparent;
cursor: pointer;
user-select: none;
transition: color .15s, border-color .15s;
}
.tab:hover { color: var(–text-2); }
.tab.active { color: var(–text); border-bottom-color: var(–scarlet); }
.tab .badge {
display: inline-block;
margin-left: 6px;
background: var(–scarlet);
color: #fff;
font-family: var(–mono);
font-size: 9px;
padding: 2px 6px;
border-radius: 999px;
letter-spacing: .5px;
vertical-align: top;
margin-top: 2px;
}

/* ===== PANELS ===== */
.panel { display: none; padding: 22px 20px 40px; max-width: 1280px; margin: 0 auto; }
.panel.active { display: block; }

.section-h {
display: flex; align-items: baseline; justify-content: space-between;
margin-bottom: 16px;
}
.section-h h2 {
font-family: var(–display);
font-size: 32px;
letter-spacing: 2px;
margin: 0;
}
.section-h .sub {
font-family: var(–mono);
font-size: 11px;
color: var(–text-3);
text-transform: uppercase;
letter-spacing: 1.5px;
}

/* ===== HOME / HUB ===== */
.hero {
position: relative;
padding: 36px 24px 32px;
background:
linear-gradient(135deg, rgba(187,0,0,.18), rgba(187,0,0,0) 60%),
var(–panel);
border: 1px solid var(–border);
border-radius: var(–r-lg);
overflow: hidden;
margin-bottom: 24px;
}
.hero::before {
content: “”; position: absolute; top: 0; right: 0;
width: 280px; height: 100%;
background: repeating-linear-gradient(
-10deg,
transparent 0 14px,
rgba(187,0,0,.08) 14px 18px
);
pointer-events: none;
}
.hero h1 {
font-family: var(–display);
font-size: 56px;
line-height: 0.95;
letter-spacing: 1.5px;
margin: 0 0 8px;
text-transform: uppercase;
}
.hero h1 .accent { color: var(–scarlet-hot); }
.hero p {
max-width: 540px;
color: var(–text-2);
margin: 0 0 18px;
font-size: 15px;
}
.hero-cta {
display: flex; flex-wrap: wrap; gap: 10px;
}
.hero-stats {
display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
gap: 14px;
margin-top: 22px;
padding-top: 22px;
border-top: 1px dashed var(–border-2);
}
.hero-stat .lbl { font-family: var(–mono); font-size: 10px; color: var(–text-3); letter-spacing: 1.5px; text-transform: uppercase; }
.hero-stat .val { font-family: var(–display); font-size: 32px; line-height: 1; }
.hero-stat .val .accent { color: var(–scarlet-hot); }

.mode-grid {
display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
gap: 14px;
}
.mode-card {
position: relative;
padding: 20px;
background: var(–panel);
border: 1px solid var(–border);
border-radius: var(–r);
cursor: pointer;
transition: transform .15s, border-color .15s, background .15s;
overflow: hidden;
}
.mode-card:hover { transform: translateY(-2px); border-color: var(–scarlet); background: linear-gradient(180deg, rgba(187,0,0,.06), transparent 60%), var(–panel); }
.mode-card .num {
font-family: var(–decal);
font-size: 12px;
color: var(–scarlet-hot);
letter-spacing: 1.5px;
margin-bottom: 8px;
}
.mode-card h3 {
font-family: var(–display);
font-size: 22px;
letter-spacing: 1.5px;
margin: 0 0 6px;
text-transform: uppercase;
}
.mode-card p { color: var(–text-2); margin: 0 0 14px; font-size: 13px; min-height: 38px; }
.mode-card .meta { font-family: var(–mono); font-size: 10px; color: var(–text-3); letter-spacing: 1.5px; text-transform: uppercase; }

/* ===== FORM CONTROLS ===== */
.btn {
display: inline-flex; align-items: center; gap: 8px;
padding: 11px 18px;
background: var(–scarlet);
color: #fff;
border: none;
border-radius: 6px;
font-family: var(–subhead);
font-size: 13px;
letter-spacing: 2px;
text-transform: uppercase;
cursor: pointer;
transition: filter .15s, transform .1s;
box-shadow: 0 4px 12px rgba(187,0,0,.35);
}
.btn:hover { filter: brightness(1.1); }
.btn:active { transform: translateY(1px); }
.btn.ghost { background: transparent; border: 1px solid var(–border-2); color: var(–text); box-shadow: none; }
.btn.ghost:hover { border-color: var(–scarlet); color: var(–scarlet-hot); }
.btn.sm { padding: 7px 12px; font-size: 11px; letter-spacing: 1.5px; }
.btn.lg { padding: 14px 24px; font-size: 15px; }
.btn.gold { background: var(–gold); color: #0a0a0c; box-shadow: 0 4px 12px rgba(240,183,56,.3); }

.input, .select {
background: var(–bg-3);
border: 1px solid var(–border);
color: var(–text);
padding: 10px 12px;
border-radius: 6px;
font-family: var(–mono);
font-size: 13px;
outline: none;
}
.input:focus, .select:focus { border-color: var(–scarlet); }
.input.lg { font-size: 18px; padding: 14px 16px; }
.field {
display: flex; flex-direction: column; gap: 6px;
}
.field .lbl { font-family: var(–mono); font-size: 10px; color: var(–text-3); letter-spacing: 1.5px; text-transform: uppercase; }

/* ===== QUIZ UI ===== */
.quiz-wrap {
display: grid;
grid-template-columns: 1fr;
gap: 20px;
}
.quiz-controls {
display: flex; flex-wrap: wrap; gap: 10px; align-items: end;
padding: 16px;
background: var(–panel);
border: 1px solid var(–border);
border-radius: var(–r);
}
.quiz-stage {
position: relative;
background:
radial-gradient(700px 350px at 50% 0%, rgba(187,0,0,.07), transparent 70%),
var(–panel);
border: 1px solid var(–border);
border-radius: var(–r-lg);
padding: 26px;
min-height: 420px;
}
.quiz-progress {
display: flex; align-items: center; justify-content: space-between;
margin-bottom: 16px;
font-family: var(–mono);
font-size: 11px;
color: var(–text-3);
letter-spacing: 1.5px;
text-transform: uppercase;
}
.quiz-progress .timer { color: var(–scarlet-hot); font-weight: 700; }
.progress-bar { height: 4px; background: var(–bg-3); border-radius: 999px; overflow: hidden; margin-bottom: 22px; }
.progress-bar .fill { height: 100%; background: linear-gradient(90deg, var(–scarlet), var(–scarlet-hot)); transition: width .25s; }

.helmet-card {
display: grid; place-items: center;
background: linear-gradient(180deg, rgba(255,255,255,.04), rgba(0,0,0,.4));
border: 1px solid var(–border-2);
border-radius: var(–r-lg);
padding: 30px;
margin-bottom: 22px;
position: relative;
overflow: hidden;
}
.helmet-card::before {
content: “”;
position: absolute;
inset: auto 0 0 0;
height: 12px;
background: repeating-linear-gradient(90deg, var(–bone) 0 18px, transparent 18px 26px);
opacity: .15;
}
.helmet-card img {
max-width: 220px; max-height: 220px;
filter: drop-shadow(0 12px 22px rgba(0,0,0,.6));
}
.helmet-card .ph {
width: 220px; height: 220px;
display: grid; place-items: center;
font-family: var(–display);
font-size: 40px;
color: var(–text-3);
letter-spacing: 2px;
border: 2px dashed var(–border-2);
border-radius: 50%;
}

.q-prompt {
font-family: var(–display);
font-size: 26px;
text-align: center;
letter-spacing: 1.5px;
margin: 0 0 18px;
}
.q-prompt .accent { color: var(–scarlet-hot); }

.choices {
display: grid;
grid-template-columns: repeat(2, 1fr);
gap: 10px;
}
.choice {
padding: 14px 16px;
background: var(–bg-3);
border: 1px solid var(–border-2);
border-radius: var(–r);
cursor: pointer;
text-align: left;
font-family: var(–body);
font-size: 14px;
color: var(–text);
transition: all .15s;
position: relative;
user-select: none;
}
.choice:hover { border-color: var(–scarlet); background: linear-gradient(180deg, rgba(187,0,0,.05), transparent), var(–bg-3); }
.choice .letter {
display: inline-block;
width: 22px;
font-family: var(–decal);
color: var(–scarlet-hot);
font-size: 14px;
}
.choice.correct {
background: linear-gradient(180deg, rgba(46,204,113,.18), transparent), var(–bg-3);
border-color: var(–green);
color: var(–green);
}
.choice.wrong {
background: linear-gradient(180deg, rgba(255,77,77,.18), transparent), var(–bg-3);
border-color: var(–red-neg);
color: var(–red-neg);
}
.choice:disabled { cursor: default; }

.fill-input {
width: 100%;
background: var(–bg-3);
border: 2px solid var(–border-2);
border-radius: var(–r);
padding: 18px 20px;
font-family: var(–display);
font-size: 28px;
letter-spacing: 2px;
color: var(–text);
outline: none;
text-transform: uppercase;
text-align: center;
}
.fill-input:focus { border-color: var(–scarlet); }
.fill-input.correct { border-color: var(–green); color: var(–green); }
.fill-input.wrong { border-color: var(–red-neg); color: var(–red-neg); }

.q-feedback {
margin-top: 16px;
padding: 14px;
background: var(–bg-3);
border-radius: var(–r);
font-size: 13px;
text-align: center;
display: none;
}
.q-feedback.active { display: block; }
.q-feedback.win { color: var(–green); border: 1px solid rgba(46,204,113,.3); }
.q-feedback.lose { color: var(–red-neg); border: 1px solid rgba(255,77,77,.3); }
.q-feedback .answer { display: block; margin-top: 4px; color: var(–text); font-family: var(–display); font-size: 18px; letter-spacing: 1.5px; }

.q-actions {
display: flex; gap: 10px; justify-content: center; margin-top: 22px;
}

/* ===== RESULT SCREEN ===== */
.result {
text-align: center;
padding: 30px 20px;
}
.result .score {
font-family: var(–display);
font-size: 96px;
line-height: 1;
margin: 12px 0;
}
.result .score .accent { color: var(–scarlet-hot); }
.result .pct { font-family: var(–mono); font-size: 16px; color: var(–text-2); }
.result .grade {
display: inline-block;
margin-top: 14px;
padding: 6px 16px;
background: var(–scarlet);
color: #fff;
font-family: var(–decal);
font-size: 16px;
border-radius: 999px;
letter-spacing: 1.5px;
}
.result-detail {
margin-top: 26px;
display: grid;
grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
gap: 12px;
text-align: left;
}
.result-detail .stat {
padding: 14px;
background: var(–bg-3);
border: 1px solid var(–border);
border-radius: var(–r);
}
.result-detail .stat .lbl { font-family: var(–mono); font-size: 10px; color: var(–text-3); letter-spacing: 1.5px; text-transform: uppercase; }
.result-detail .stat .val { font-family: var(–display); font-size: 24px; }

/* ===== TEAM SPOTLIGHT (Ohio State) ===== */
.osu-mode { background: linear-gradient(180deg, rgba(187,0,0,.05), transparent 30%), var(–bg); }

.spotlight-hero {
position: relative;
padding: 40px 28px;
background:
radial-gradient(800px 400px at 100% 0%, rgba(187,0,0,.35), transparent 60%),
linear-gradient(180deg, #1a0707, #0d0202);
border: 1px solid rgba(187,0,0,.4);
border-radius: var(–r-lg);
margin-bottom: 24px;
overflow: hidden;
}
.spotlight-hero::after {
content: “OHIO”;
position: absolute;
right: -20px; bottom: -40px;
font-family: var(–display);
font-size: 220px;
letter-spacing: 8px;
color: rgba(187,0,0,.08);
pointer-events: none;
line-height: 1;
}
.spotlight-hero h1 {
font-family: var(–display);
font-size: 64px;
letter-spacing: 3px;
margin: 0;
line-height: .95;
}
.spotlight-hero h1 span { display: block; color: var(–scarlet-hot); font-size: 80px; }
.spotlight-hero .meta {
margin-top: 14px;
font-family: var(–mono);
font-size: 12px;
color: var(–text-2);
letter-spacing: 1.5px;
}
.spotlight-hero .stats-row {
display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
gap: 18px;
margin-top: 24px;
padding-top: 24px;
border-top: 1px dashed rgba(187,0,0,.4);
position: relative; z-index: 1;
}
.spotlight-hero .stat .lbl { font-family: var(–mono); font-size: 10px; color: rgba(245,240,225,.5); letter-spacing: 1.5px; text-transform: uppercase; }
.spotlight-hero .stat .val { font-family: var(–display); font-size: 36px; line-height: 1; }

.spotlight-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 16px;
}
@media (max-width: 720px) { .spotlight-grid { grid-template-columns: 1fr; } }

.fact-card {
padding: 18px 20px;
background: var(–panel);
border: 1px solid var(–border);
border-radius: var(–r);
}
.fact-card h3 {
font-family: var(–display);
font-size: 18px;
letter-spacing: 1.5px;
margin: 0 0 12px;
color: var(–scarlet-hot);
text-transform: uppercase;
}
.fact-card ul { margin: 0; padding-left: 18px; color: var(–text-2); }
.fact-card ul li { margin-bottom: 6px; }
.fact-card ul li strong { color: var(–text); }
.fact-card.full { grid-column: 1 / -1; }

.qmark-list {
list-style: none;
padding: 0;
margin: 0;
}
.qmark-list li {
padding: 10px 0;
border-bottom: 1px dashed var(–border);
display: flex;
gap: 12px;
}
.qmark-list li:last-child { border-bottom: none; }
.qmark-list .q {
font-family: var(–mono);
font-size: 11px;
color: var(–scarlet-hot);
flex-shrink: 0;
min-width: 28px;
}
.qmark-list .a {
color: var(–text-2);
font-size: 13px;
}
.qmark-list .a strong { color: var(–text); }

/* ===== MICHIGAN HATE TAB ===== */
.michigan-mode {
position: relative;
padding: 30px 24px;
background:
repeating-linear-gradient(45deg, transparent 0 12px, rgba(255,203,5,.025) 12px 13px),
linear-gradient(180deg, #0a0a14, #0a0a0c);
border: 1px solid var(–border);
border-radius: var(–r-lg);
margin-bottom: 24px;
overflow: hidden;
}
.michigan-mode::before {
content: “TTUN”;
position: absolute;
top: 20px; right: 30px;
font-family: var(–display);
font-size: 180px;
color: rgba(255,203,5,.06);
letter-spacing: 6px;
line-height: 1;
pointer-events: none;
text-decoration: line-through;
text-decoration-color: var(–scarlet);
text-decoration-thickness: 12px;
}
.michigan-mode h1 {
font-family: var(–display);
font-size: 56px;
letter-spacing: 2px;
margin: 0 0 4px;
position: relative;
}
.michigan-mode h1 .strike {
text-decoration: line-through;
text-decoration-color: var(–scarlet);
text-decoration-thickness: 6px;
color: var(–text-3);
}
.michigan-mode .tagline {
font-family: var(–mono);
font-size: 12px;
color: var(–text-2);
letter-spacing: 1.5px;
position: relative;
margin-bottom: 22px;
}
.michigan-mode .tagline .red { color: var(–scarlet-hot); }

.rivalry-grid {
display: grid; grid-template-columns: 1fr 1fr;
gap: 14px;
position: relative;
}
@media (max-width: 720px) { .rivalry-grid { grid-template-columns: 1fr; } }

.rivalry-card {
padding: 16px 18px;
background: rgba(15,15,18,.85);
border: 1px solid var(–border);
border-left: 3px solid var(–scarlet);
border-radius: 6px;
}
.rivalry-card h3 {
font-family: var(–display);
font-size: 18px;
letter-spacing: 1.5px;
margin: 0 0 8px;
color: var(–scarlet-hot);
text-transform: uppercase;
}
.rivalry-card p { color: var(–text-2); margin: 6px 0; font-size: 13px; }
.rivalry-card .quote {
display: block;
font-style: italic;
color: var(–bone);
font-size: 15px;
padding: 10px 14px;
border-left: 2px solid var(–gold);
margin: 10px 0;
}
.rivalry-card .quote .src { display: block; margin-top: 6px; font-style: normal; font-family: var(–mono); font-size: 10px; color: var(–text-3); letter-spacing: 1px; }

.scoreboard {
background: #050505;
border: 1px solid var(–border-2);
border-radius: var(–r);
padding: 18px 22px;
display: grid;
grid-template-columns: 1fr auto 1fr;
align-items: center;
gap: 18px;
position: relative;
margin: 14px 0;
}
.scoreboard .team { text-align: center; }
.scoreboard .team .name {
font-family: var(–display);
font-size: 22px;
letter-spacing: 1.5px;
}
.scoreboard .team.osu .name { color: var(–scarlet-hot); }
.scoreboard .team.mich .name { color: var(–maize); opacity: .55; }
.scoreboard .team .wins {
font-family: var(–decal);
font-size: 60px;
color: var(–text);
line-height: 1;
}
.scoreboard .team.mich .wins { opacity: .5; }
.scoreboard .vs {
font-family: var(–mono);
font-size: 11px;
color: var(–text-3);
letter-spacing: 1.5px;
text-align: center;
}
.scoreboard .vs .meta { display: block; margin-top: 4px; color: var(–scarlet-hot); }

.countdown {
display: flex; gap: 8px; justify-content: center;
margin: 18px 0 6px;
}
.countdown .unit {
background: #050505;
border: 1px solid var(–border-2);
border-radius: 6px;
padding: 12px 14px;
