const QUIZ_LEN = 10;

function buildFilterUI(mode) {
  const conferences = Object.keys(state.byConference)
    .filter(c => c !== 'Other')
    .sort((a,b) => state.byConference[b].length - state.byConference[a].length);
  return `<div class="quiz-controls">
    <div class="field">
      <span class="lbl">Division</span>
      <select class="select" id="${mode}-div">
        <option value="all">All (FBS + FCS)</option>
        <option value="FBS" selected>FBS only</option>
        <option value="FCS">FCS only</option>
      </select>
    </div>
    <div class="field">
      <span class="lbl">Conference</span>
      <select class="select" id="${mode}-conf">
        <option value="all">All conferences</option>
        ${conferences.map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)} (${state.byConference[c].length})</option>`).join('')}
      </select>
    </div>
    <div class="field">
      <span class="lbl">Length</span>
      <select class="select" id="${mode}-len">
        <option value="10" selected>10 questions</option>
        <option value="15">15 questions</option>
        <option value="20">20 questions</option>
      </select>
    </div>
    <button class="btn" onclick="startMode('${mode}')">START</button>
  </div>`;
}

function startMode(mode) {
  const div = document.getElementById(`${mode}-div`)?.value || 'FBS';
  const conf = document.getElementById(`${mode}-conf`)?.value || 'all';
  const len = +(document.getElementById(`${mode}-len`)?.value || 10);
  const pool = poolFor({ division: div, conference: conf });
  if (pool.length < 4) {
    alert('Not enough teams in this filter. Pick a broader scope.');
    return;
  }
  state.current = { mode, pool, len, idx: 0, correct: 0, answers: [] };
  if (mode === 'helmet') renderHelmetQ();
  if (mode === 'fill') renderFillQ();
  if (mode === 'conference') renderConfQ();
  if (mode === 'location') renderLocQ();
}
window.startMode = startMode;

function progressBar() {
  const c = state.current;
  return `<div class="quiz-progress">
    <span>QUESTION <strong style="color:var(--text)">${c.idx + 1}</strong> / ${c.len}</span>
    <span>SCORE: <strong style="color:var(--scarlet-hot)">${c.correct}</strong></span>
  </div>
  <div class="progress-bar"><div class="fill" style="width:${(c.idx / c.len) * 100}%"></div></div>`;
}

function quizResult() {
  const c = state.current;
  bumpScore(c.mode, c.correct, c.len);
  const pct = Math.round(c.correct / c.len * 100);
  const grade = pct >= 90 ? 'A+' : pct >= 80 ? 'A' : pct >= 70 ? 'B' : pct >= 60 ? 'C' : pct >= 50 ? 'D' : 'F';
  const trash = pct >= 90 ? "You're built different. The real ones know." :
                pct >= 80 ? "Solid Saturday IQ. Saturdays are your day." :
                pct >= 70 ? "Decent fan. Get to a few more games." :
                pct >= 60 ? "You watch RedZone and bail. We see you." :
                pct >= 50 ? "Casual energy detected." :
                "Did you mean to be on the soccer trivia app?";
  const wrap = state.panelEl();
  wrap.innerHTML = `<div class="quiz-stage"><div class="result">
    <div class="muted" style="font-family:var(--mono);font-size:11px;letter-spacing:1.5px">FINAL</div>
    <div class="score"><span class="accent">${c.correct}</span><span style="color:var(--text-3)">/</span>${c.len}</div>
    <div class="pct">${pct}% · <span class="grade">${grade}</span></div>
    <div style="margin-top:18px;color:var(--text-2);font-size:14px">${trash}</div>
    <div class="result-detail">
      ${c.answers.map((a,i) => `<div class="stat">
        <div class="lbl">Q${i+1} · ${a.correct ? '<span style="color:var(--green)">✓</span>' : '<span style="color:var(--red-neg)">✗</span>'}</div>
        <div class="val" style="font-size:14px;font-family:var(--body);text-transform:none">${escapeHtml(a.team.fullName || a.team.name)}</div>
      </div>`).join('')}
    </div>
    <div class="q-actions">
      <button class="btn lg" onclick="startMode('${c.mode}')">PLAY AGAIN</button>
      <button class="btn ghost lg" onclick="goTab('home')">HOME</button>
    </div>
  </div></div>`;
}

state.panelEl = () => {
  const m = state.current?.mode;
  if (m === 'helmet') return document.getElementById('helmetQuiz');
  if (m === 'fill') return document.getElementById('fillQuiz');
  if (m === 'conference') return document.getElementById('confQuiz');
  if (m === 'location') return document.getElementById('locQuiz');
  return document.body;
};

function nextQuestion() {
  state.current.idx++;
  const m = state.current.mode;
  if (state.current.idx >= state.current.len) {
    quizResult();
    return;
  }
  if (m === 'helmet') renderHelmetQ();
  if (m === 'fill') renderFillQ();
  if (m === 'conference') renderConfQ();
  if (m === 'location') renderLocQ();
}
window.nextQuestion = nextQuestion;

