const GRID_CONFIGS = [
  { rows: ['SEC', 'Big Ten', 'Big 12'], cols: ['Located in Texas', 'Founded before 1900', 'Mascot is a Tiger or Bulldog'] },
  { rows: ['ACC', 'SEC', 'Big Ten'], cols: ['Located in California or Florida', 'Has won a national title', 'Mascot is a feline'] },
  { rows: ['Big 12', 'Sun Belt', 'MAC'], cols: ['City contains a directional word', 'Located in the Midwest', 'State capital home'] },
  { rows: ['SEC', 'ACC', 'American'], cols: ['Located in NC or SC', 'Mascot starts with vowel', 'School name has 2+ words'] },
  { rows: ['Big Ten', 'Big 12', 'Mountain West'], cols: ['Located in mountain time zone', 'Mascot is a bird', 'Has played in a Rose Bowl'] }
];
function todayKey() { const d = new Date(); return `${d.getFullYear()}-${d.getMonth()+1}-${d.getDate()}`; }
function pickDailyGridConfig() {
  const seed = todayKey();
  const sum = seed.split('').reduce((s,c) => s + c.charCodeAt(0), 0);
  return GRID_CONFIGS[sum % GRID_CONFIGS.length];
}
function getGridState() {
  const all = ls_get(STORE.grid, {});
  return all[todayKey()] || { picks: {}, lockedTeams: [] };
}
function saveGridState(s) {
  const all = ls_get(STORE.grid, {});
  all[todayKey()] = s;
  ls_set(STORE.grid, all);
}
function renderDailyGrid() {
  const wrap = document.getElementById('dailyGridWrap');
  document.getElementById('gridDate').textContent = new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' });
  const cfg = pickDailyGridConfig();
  const gs = getGridState();
  wrap.innerHTML = `<div class="daily-grid-wrap">
    <div style="text-align:center;margin-bottom:18px">
      <div style="font-family:var(--mono);font-size:11px;color:var(--text-3);letter-spacing:1.5px">${Object.keys(gs.picks).length} / 9 cells filled</div>
    </div>
    <div class="daily-grid">
      <div class="corner"></div>
      ${cfg.cols.map(c => `<div class="col-h">${escapeHtml(c)}</div>`).join('')}
      ${cfg.rows.map((row, ri) => `
        <div class="row-h">${escapeHtml(row)}</div>
        ${cfg.cols.map((col, ci) => {
          const key = `${ri}-${ci}`;
          const filled = gs.picks[key];
          return `<div class="cell ${filled ? 'filled' : ''}" onclick="fillGridCell(${ri},${ci})">
            ${filled ? `<span class="name">${escapeHtml(filled)}</span>` : `<span class="plus">+</span>`}
          </div>`;
        }).join('')}
      `).join('')}
    </div>
    <p class="muted" style="margin-top:18px;text-align:center;font-size:12px;line-height:1.5">Tap any cell to type a team that satisfies <strong style="color:var(--text-2)">both</strong> the row conference and column criterion. No team can be used twice. New grid each day.</p>
    <div style="text-align:center;margin-top:14px">
      <button class="btn ghost sm" onclick="resetDailyGrid()">RESET TODAY'S GRID</button>
    </div>
  </div>`;
}
window.fillGridCell = function(ri, ci) {
  const ans = prompt('Type a team that fits this cell (e.g., "Ohio State", "Alabama"):');
  if (!ans) return;
  const gs = getGridState();
  const key = `${ri}-${ci}`;
  const teamMatch = state.teams.find(t =>
    (t.fullName || '').toLowerCase().includes(ans.toLowerCase()) ||
    (t.name || '').toLowerCase() === ans.toLowerCase()
  );
  if (!teamMatch) { alert('Team not found in our database. Try the school name like "Ohio State".'); return; }
  if (gs.lockedTeams.includes(teamMatch.id)) { alert('That team is already used in another cell.'); return; }
  gs.picks[key] = teamMatch.fullName || teamMatch.name;
  gs.lockedTeams.push(teamMatch.id);
  saveGridState(gs);
  renderDailyGrid();
};
window.resetDailyGrid = function() {
  if (!confirm("Reset today's grid? Your progress will be lost.")) return;
  const all = ls_get(STORE.grid, {});
  delete all[todayKey()];
  ls_set(STORE.grid, all);
  renderDailyGrid();
};

