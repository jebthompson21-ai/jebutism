   ============================================================ */
function startHelmetQuiz() {
  const wrap = document.getElementById('helmetQuiz');
  wrap.innerHTML = buildFilterUI('helmet') + `<div class="empty"><span class="big">READY</span>Pick filters, hit START to begin the helmet quiz.</div>`;
}
function renderHelmetQ() {
  const c = state.current;
  const team = pick(c.pool);
  const wrongs = pickN(c.pool, 3, [team]);
  const choices = shuffle([team, ...wrongs]);
  c.currentTeam = team;
  c.choices = choices;
  const wrap = state.panelEl();
  wrap.innerHTML = `<div class="quiz-stage">
    ${progressBar()}
    <div class="helmet-card">
      <img src="${team.logo}" alt="" onerror="this.replaceWith(Object.assign(document.createElement('div'),{className:'ph',textContent:'?'}))" />
    </div>
    <h3 class="q-prompt">Which program is this?</h3>
    <div class="choices">
      ${choices.map((t, i) => `<button class="choice" data-i="${i}" onclick="answerHelmet(${i})">
        <span class="letter">${String.fromCharCode(65+i)}</span>${escapeHtml(t.fullName || (t.name + ' ' + t.mascot))}
      </button>`).join('')}
    </div>
    <div class="q-feedback" id="qf"></div>
  </div>`;
}
window.answerHelmet = function(i) {
  const c = state.current;
  const correct = c.choices[i].id === c.currentTeam.id;
  c.answers.push({ team: c.currentTeam, correct });
  if (correct) c.correct++;
  document.querySelectorAll('.choice').forEach((el, idx) => {
    el.disabled = true;
    if (c.choices[idx].id === c.currentTeam.id) el.classList.add('correct');
    else if (idx === i) el.classList.add('wrong');
  });
  const fb = document.getElementById('qf');
  fb.classList.add('active', correct ? 'win' : 'lose');
  fb.innerHTML = `${correct ? '✓ CORRECT' : '✗ WRONG'} <span class="answer">${escapeHtml(c.currentTeam.fullName || (c.currentTeam.name + ' ' + c.currentTeam.mascot))} · ${escapeHtml(c.currentTeam.conference || '')}</span>`;
  setTimeout(nextQuestion, 1100);
};

